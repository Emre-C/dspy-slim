{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PredictPipelineFixtures",
  "description": "Behavioral tests for Predict forward pipeline validation and preprocessing",
  "cases": [
    {
      "id": "no_lm_configured_errors",
      "signature": "question -> answer",
      "settings_lm": null,
      "predict_lm": null,
      "kwargs": { "question": "Why?" },
      "expected_error": "No LM is loaded"
    },
    {
      "id": "string_lm_errors",
      "signature": "question -> answer",
      "settings_lm": null,
      "predict_lm": null,
      "kwargs": { "question": "Why?", "lm": "openai/gpt-4o-mini" },
      "expected_error": "must be an instance of"
    },
    {
      "id": "lm_resolution_kwargs_first",
      "signature": "question -> answer",
      "settings_lm": "settings_lm",
      "predict_lm": "predict_lm",
      "kwargs_lm": "kwargs_lm",
      "expected_resolved_lm": "kwargs_lm"
    },
    {
      "id": "lm_resolution_predict_second",
      "signature": "question -> answer",
      "settings_lm": "settings_lm",
      "predict_lm": "predict_lm",
      "kwargs_lm": null,
      "expected_resolved_lm": "predict_lm"
    },
    {
      "id": "lm_resolution_settings_fallback",
      "signature": "question -> answer",
      "settings_lm": "settings_lm",
      "predict_lm": null,
      "kwargs_lm": null,
      "expected_resolved_lm": "settings_lm"
    },
    {
      "id": "temperature_auto_adjust",
      "signature": "question -> answer",
      "config": { "n": 3, "temperature": null },
      "expected_config_temperature": 0.7
    },
    {
      "id": "temperature_no_adjust_single",
      "signature": "question -> answer",
      "config": { "n": 1, "temperature": null },
      "expected_config_temperature": null
    },
    {
      "id": "temperature_no_adjust_high",
      "signature": "question -> answer",
      "config": { "n": 3, "temperature": 0.9 },
      "expected_config_temperature": 0.9
    },
    {
      "id": "default_field_values_populated",
      "signature_fields": {
        "question": { "kind": "input", "default": null },
        "context": { "kind": "input", "default": "none provided" }
      },
      "kwargs": { "question": "Why?" },
      "expected_kwargs_after_preprocess": { "question": "Why?", "context": "none provided" }
    },
    {
      "id": "extra_fields_warned_not_errored",
      "signature": "question -> answer",
      "kwargs": { "question": "Why?", "extra_field": "should warn" },
      "expected_warning": "not in signature"
    },
    {
      "id": "positional_args_error",
      "signature": "question -> answer",
      "positional_args": ["Why?"],
      "expected_error": "Positional arguments are not allowed"
    },
    {
      "id": "config_merge_order",
      "predict_config": { "temperature": 0.5, "max_tokens": 100 },
      "call_config": { "temperature": 0.9 },
      "expected_merged_config": { "temperature": 0.9, "max_tokens": 100 }
    }
  ]
}
