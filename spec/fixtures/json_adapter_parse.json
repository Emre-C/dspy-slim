{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JSONAdapterParseFixtures",
  "description": "Behavioral tests for JSONAdapter JSON-based parsing",
  "cases": [
    {
      "id": "valid_json_object",
      "signature_outputs": ["answer"],
      "completion": "{\"answer\": \"Paris\"}",
      "expected": { "answer": "Paris" }
    },
    {
      "id": "multi_field_json",
      "signature_outputs": ["reasoning", "answer"],
      "completion": "{\"reasoning\": \"Capital of France\", \"answer\": \"Paris\"}",
      "expected": {
        "reasoning": "Capital of France",
        "answer": "Paris"
      }
    },
    {
      "id": "json_with_extra_fields_filtered",
      "signature_outputs": ["answer"],
      "completion": "{\"answer\": \"Paris\", \"extra\": \"ignored\"}",
      "expected": { "answer": "Paris" }
    },
    {
      "id": "json_embedded_in_text",
      "signature_outputs": ["answer"],
      "completion": "Here is my answer: {\"answer\": \"Paris\"} hope that helps",
      "expected": { "answer": "Paris" }
    },
    {
      "id": "json_repair_malformed",
      "signature_outputs": ["answer"],
      "completion": "{answer: 'Paris'}",
      "expected": { "answer": "Paris" }
    },
    {
      "id": "typed_output_int",
      "signature_outputs": ["count"],
      "output_types": { "count": "int" },
      "completion": "{\"count\": \"42\"}",
      "expected": { "count": 42 }
    },
    {
      "id": "typed_output_bool",
      "signature_outputs": ["verdict"],
      "output_types": { "verdict": "bool" },
      "completion": "{\"verdict\": true}",
      "expected": { "verdict": true }
    },
    {
      "id": "missing_field_errors",
      "signature_outputs": ["answer", "score"],
      "completion": "{\"answer\": \"Paris\"}",
      "expected_error": "AdapterParseError"
    },
    {
      "id": "non_json_errors",
      "signature_outputs": ["answer"],
      "completion": "This is not JSON at all",
      "expected_error": "AdapterParseError"
    }
  ]
}
