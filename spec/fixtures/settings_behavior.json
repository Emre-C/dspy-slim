{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SettingsBehaviorFixtures",
  "description": "Behavioral tests for Settings configure/context semantics",
  "cases": [
    {
      "id": "configure_sets_global",
      "ops": [
        { "action": "configure", "kwargs": { "lm": "lm_a" } },
        { "action": "read", "key": "lm", "expected": "lm_a" }
      ]
    },
    {
      "id": "context_overrides_then_restores",
      "ops": [
        { "action": "configure", "kwargs": { "lm": "lm_a" } },
        { "action": "context_enter", "kwargs": { "lm": "lm_b" } },
        { "action": "read", "key": "lm", "expected": "lm_b" },
        { "action": "context_exit" },
        { "action": "read", "key": "lm", "expected": "lm_a" }
      ]
    },
    {
      "id": "context_inherits_unoverridden_keys",
      "ops": [
        { "action": "configure", "kwargs": { "lm": "lm_a", "adapter": "adapter_a" } },
        { "action": "context_enter", "kwargs": { "lm": "lm_b" } },
        { "action": "read", "key": "adapter", "expected": "adapter_a" },
        { "action": "context_exit" }
      ]
    },
    {
      "id": "second_thread_configure_errors",
      "ops": [
        { "action": "configure", "kwargs": { "lm": "lm_a" }, "thread": 1 },
        { "action": "configure", "kwargs": { "lm": "lm_b" }, "thread": 2, "expected_error": "RuntimeError" }
      ]
    },
    {
      "id": "any_thread_can_context",
      "ops": [
        { "action": "configure", "kwargs": { "lm": "lm_a" }, "thread": 1 },
        { "action": "context_enter", "kwargs": { "lm": "lm_b" }, "thread": 2 },
        { "action": "read", "key": "lm", "expected": "lm_b", "thread": 2 },
        { "action": "context_exit", "thread": 2 },
        { "action": "read", "key": "lm", "expected": "lm_a", "thread": 2 }
      ]
    },
    {
      "id": "defaults_present_without_configure",
      "ops": [
        { "action": "read", "key": "num_threads", "expected": 8 },
        { "action": "read", "key": "max_errors", "expected": 10 },
        { "action": "read", "key": "disable_history", "expected": false },
        { "action": "read", "key": "lm", "expected": null }
      ]
    }
  ]
}
