{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SignatureOpsFixtures",
  "description": "Behavioral tests for Signature structural operations",
  "cases": [
    {
      "id": "append_output_field",
      "base_sig": "question -> answer",
      "op": "append",
      "field_name": "confidence",
      "field_kind": "output",
      "field_type": "float",
      "expected_output_fields_ordered": ["answer", "confidence"]
    },
    {
      "id": "prepend_output_field",
      "base_sig": "question -> answer",
      "op": "prepend",
      "field_name": "reasoning",
      "field_kind": "output",
      "field_type": "str",
      "expected_output_fields_ordered": ["reasoning", "answer"]
    },
    {
      "id": "delete_field",
      "base_sig": "question, context -> answer",
      "op": "delete",
      "field_name": "context",
      "expected_input_fields": ["question"],
      "expected_output_fields": ["answer"]
    },
    {
      "id": "with_instructions",
      "base_sig": "question -> answer",
      "op": "with_instructions",
      "instructions": "Answer the question concisely.",
      "expected_instructions": "Answer the question concisely."
    },
    {
      "id": "default_instructions_generated",
      "base_sig": "question, context -> answer",
      "op": "check_default_instructions",
      "expected_instructions": "Given the fields `question`, `context`, produce the fields `answer`."
    },
    {
      "id": "append_input_field",
      "base_sig": "question -> answer",
      "op": "append",
      "field_name": "trajectory",
      "field_kind": "input",
      "field_type": "str",
      "expected_input_fields_ordered": ["question", "trajectory"]
    },
    {
      "id": "fields_order_inputs_before_outputs",
      "base_sig": "a, b -> x, y",
      "op": "check_fields_order",
      "expected_fields_ordered": ["a", "b", "x", "y"]
    },
    {
      "id": "signature_string",
      "base_sig": "question, context -> answer",
      "op": "check_signature_string",
      "expected": "question, context -> answer"
    },
    {
      "id": "disjoint_keys_invariant",
      "base_sig": "a, b -> x, y",
      "op": "check_disjoint",
      "expected_intersection": []
    }
  ]
}
