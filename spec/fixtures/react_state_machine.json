{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReActStateMachineFixtures",
  "description": "Behavioral tests for ReAct agent loop transitions",
  "cases": [
    {
      "id": "immediate_finish",
      "max_iters": 5,
      "tool_sequence": [
        { "tool_name": "finish", "tool_args": {} }
      ],
      "expected_iterations": 1,
      "expected_terminal_state": "done"
    },
    {
      "id": "tool_then_finish",
      "max_iters": 5,
      "tool_sequence": [
        { "tool_name": "search", "tool_args": { "query": "test" }, "observation": "result" },
        { "tool_name": "finish", "tool_args": {} }
      ],
      "expected_iterations": 2,
      "expected_terminal_state": "done"
    },
    {
      "id": "max_iters_exhausted",
      "max_iters": 3,
      "tool_sequence": [
        { "tool_name": "search", "tool_args": {}, "observation": "r1" },
        { "tool_name": "search", "tool_args": {}, "observation": "r2" },
        { "tool_name": "search", "tool_args": {}, "observation": "r3" }
      ],
      "expected_iterations": 3,
      "expected_terminal_state": "done",
      "comment": "extraction still runs after hitting max_iters"
    },
    {
      "id": "value_error_breaks_loop",
      "max_iters": 5,
      "tool_sequence": [
        { "tool_name": "search", "tool_args": {}, "observation": "r1" },
        { "error": "ValueError" }
      ],
      "expected_iterations": 2,
      "expected_terminal_state": "done",
      "comment": "ValueError from react predict → breaks loop → runs extract"
    },
    {
      "id": "tool_error_captured_as_observation",
      "max_iters": 5,
      "tool_sequence": [
        { "tool_name": "failing_tool", "tool_args": {}, "tool_raises": "RuntimeError", "observation_prefix": "Execution error" },
        { "tool_name": "finish", "tool_args": {} }
      ],
      "expected_iterations": 2,
      "expected_terminal_state": "done",
      "comment": "tool exceptions become trajectory observations, not fatal errors"
    },
    {
      "id": "trajectory_keys_structure",
      "max_iters": 5,
      "tool_sequence": [
        { "tool_name": "search", "tool_args": { "q": "x" }, "observation": "found" },
        { "tool_name": "finish", "tool_args": {} }
      ],
      "expected_trajectory_keys": [
        "thought_0", "tool_name_0", "tool_args_0", "observation_0",
        "thought_1", "tool_name_1", "tool_args_1", "observation_1"
      ]
    },
    {
      "id": "truncation_drops_oldest_4_keys",
      "trajectory_before": {
        "thought_0": "t0", "tool_name_0": "search", "tool_args_0": "{}", "observation_0": "r0",
        "thought_1": "t1", "tool_name_1": "search", "tool_args_1": "{}", "observation_1": "r1"
      },
      "expected_trajectory_after_truncation_keys": [
        "thought_1", "tool_name_1", "tool_args_1", "observation_1"
      ]
    },
    {
      "id": "truncation_of_minimal_trajectory_errors",
      "trajectory_before": {
        "thought_0": "t0", "tool_name_0": "search", "tool_args_0": "{}", "observation_0": "r0"
      },
      "truncation_expected_error": "cannot be truncated"
    },
    {
      "id": "finish_tool_always_present",
      "tools": ["search", "calculate"],
      "expected_tool_names": ["search", "calculate", "finish"]
    },
    {
      "id": "react_signature_structure",
      "original_signature": "question -> answer",
      "expected_react_inputs": ["question", "trajectory"],
      "expected_react_outputs": ["next_thought", "next_tool_name", "next_tool_args"]
    },
    {
      "id": "extract_signature_structure",
      "original_signature": "question -> answer",
      "expected_extract_inputs": ["question", "answer", "trajectory"],
      "comment": "fallback_signature includes original output fields as inputs"
    }
  ]
}
