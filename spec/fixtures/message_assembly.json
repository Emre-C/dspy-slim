{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MessageAssemblyFixtures",
  "description": "Behavioral tests for adapter message assembly order and structure",
  "cases": [
    {
      "id": "minimal_no_demos",
      "signature": "question -> answer",
      "demos": [],
      "inputs": { "question": "What is 2+2?" },
      "expected_message_roles": ["system", "user"],
      "expected_system_contains": ["input fields", "output fields"],
      "expected_last_user_contains": ["question"]
    },
    {
      "id": "with_complete_demos",
      "signature": "question -> answer",
      "demos": [
        { "question": "What is 1+1?", "answer": "2" }
      ],
      "inputs": { "question": "What is 2+2?" },
      "expected_message_roles": ["system", "user", "assistant", "user"],
      "comment": "demo_user, demo_assistant, then final user"
    },
    {
      "id": "with_incomplete_demo",
      "signature": "question, context -> answer",
      "demos": [
        { "question": "What?", "answer": "That." }
      ],
      "inputs": { "question": "Why?", "context": "some context" },
      "expected_message_roles": ["system", "user", "assistant", "user"],
      "comment": "incomplete demos (missing context) still emitted if has input+output"
    },
    {
      "id": "demo_ordering_incomplete_before_complete",
      "signature": "question -> answer",
      "demos": [
        { "question": "Q1", "answer": "A1" },
        { "question": "Q2" }
      ],
      "inputs": { "question": "Q3" },
      "comment": "incomplete demos appear before complete demos in message sequence"
    },
    {
      "id": "chat_adapter_field_headers_in_user_message",
      "adapter": "chat",
      "signature": "question -> answer",
      "inputs": { "question": "Why?" },
      "expected_user_content_contains": ["[[ ## question ## ]]"]
    },
    {
      "id": "chat_adapter_completed_marker_in_assistant",
      "adapter": "chat",
      "signature": "question -> answer",
      "demo_output": { "answer": "Because." },
      "expected_assistant_content_contains": ["[[ ## completed ## ]]"]
    },
    {
      "id": "json_adapter_assistant_is_json",
      "adapter": "json",
      "signature": "question -> answer",
      "demo_output": { "answer": "Because." },
      "expected_assistant_content_is_valid_json": true
    }
  ]
}
