{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PredictionOpsFixtures",
  "description": "Behavioral tests for Prediction numeric protocol and construction",
  "cases": [
    {
      "id": "from_completions_single",
      "op": "from_completions",
      "completions": { "answer": ["Paris"], "reasoning": ["France capital"] },
      "expected_store": { "answer": "Paris", "reasoning": "France capital" },
      "expected_completions_len": 1
    },
    {
      "id": "from_completions_multi",
      "op": "from_completions",
      "completions": { "answer": ["Paris", "Lyon"], "score": [0.9, 0.1] },
      "expected_store": { "answer": "Paris", "score": 0.9 },
      "expected_completions_len": 2
    },
    {
      "id": "float_conversion",
      "op": "float",
      "store": { "answer": "x", "score": 0.85 },
      "expected": 0.85
    },
    {
      "id": "float_missing_score_errors",
      "op": "float",
      "store": { "answer": "x" },
      "expected_error": "does not have a 'score' field"
    },
    {
      "id": "addition",
      "op": "add",
      "a_store": { "score": 0.5 },
      "b_value": 0.3,
      "expected": 0.8
    },
    {
      "id": "division",
      "op": "div",
      "store": { "score": 0.9 },
      "divisor": 3,
      "expected": 0.3
    },
    {
      "id": "comparison_lt",
      "op": "lt",
      "a_store": { "score": 0.3 },
      "b_value": 0.5,
      "expected": true
    },
    {
      "id": "comparison_ge",
      "op": "ge",
      "a_store": { "score": 0.5 },
      "b_value": 0.5,
      "expected": true
    },
    {
      "id": "input_keys_always_absent",
      "op": "check_input_keys_absent",
      "store": { "answer": "x" },
      "comment": "Prediction deletes _input_keys and _demos from Example. hasattr(_input_keys) must be false."
    }
  ]
}
