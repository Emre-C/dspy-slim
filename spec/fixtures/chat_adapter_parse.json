{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChatAdapterParseFixtures",
  "description": "Behavioral tests for ChatAdapter bracket-delimited parsing",
  "cases": [
    {
      "id": "single_output_field",
      "signature_outputs": ["answer"],
      "completion": "[[ ## answer ## ]]\nParis\n\n[[ ## completed ## ]]",
      "expected": { "answer": "Paris" }
    },
    {
      "id": "multi_output_fields",
      "signature_outputs": ["reasoning", "answer"],
      "completion": "[[ ## reasoning ## ]]\nFrance is a country in Europe.\n\n[[ ## answer ## ]]\nParis\n\n[[ ## completed ## ]]",
      "expected": {
        "reasoning": "France is a country in Europe.",
        "answer": "Paris"
      }
    },
    {
      "id": "multiline_field_value",
      "signature_outputs": ["answer"],
      "completion": "[[ ## answer ## ]]\nLine 1\nLine 2\nLine 3\n\n[[ ## completed ## ]]",
      "expected": { "answer": "Line 1\nLine 2\nLine 3" }
    },
    {
      "id": "ignores_unknown_headers",
      "signature_outputs": ["answer"],
      "completion": "[[ ## unknown ## ]]\nfoo\n\n[[ ## answer ## ]]\nbar\n\n[[ ## completed ## ]]",
      "expected": { "answer": "bar" }
    },
    {
      "id": "first_occurrence_wins",
      "signature_outputs": ["answer"],
      "completion": "[[ ## answer ## ]]\nfirst\n\n[[ ## answer ## ]]\nsecond\n\n[[ ## completed ## ]]",
      "expected": { "answer": "first" }
    },
    {
      "id": "missing_field_errors",
      "signature_outputs": ["answer", "confidence"],
      "completion": "[[ ## answer ## ]]\nParis\n\n[[ ## completed ## ]]",
      "expected_error": "AdapterParseError"
    },
    {
      "id": "empty_completion_errors",
      "signature_outputs": ["answer"],
      "completion": "",
      "expected_error": "AdapterParseError"
    }
  ]
}
